# Copy to .env and fill in to enable the frontend's optional integrations.
# Everything here is OPTIONAL — the stack runs without it (AI area briefs stay off).

# OpenAI-compatible endpoint for AI area briefs
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# Brave Search (news sources for area briefs)
BRAVE_SEARCH_API_KEY=
BRAVE_SEARCH_BASE_URL=
BRAVE_SEARCH_COUNTRY=

# Map tile server URL (falls back to a default in-app if unset)
HINATION_TILE_URL=

# Area-brief cache TTL in minutes
AREA_BRIEF_TTL_MINUTES=

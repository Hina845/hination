# Copy to .env and fill in to enable the frontend's optional integrations.
# Everything here is OPTIONAL — the stack runs without it (AI area briefs stay off).

# OpenAI-compatible endpoint for AI area briefs
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# Brave Search (news sources for area briefs)
BRAVE_SEARCH_API_KEY=
BRAVE_SEARCH_BASE_URL=
BRAVE_SEARCH_COUNTRY=

# Map tile server URL (falls back to a default in-app if unset)
HINATION_TILE_URL=

# Area-brief cache TTL in minutes
AREA_BRIEF_TTL_MINUTES=

# ===========================================================================
# Backend forecast pipeline (live GFS pull + disaster model)
# All OPTIONAL — sensible defaults are baked in; override only to tune.
# ===========================================================================

# --- Live weather source: NOAA GFS via Open-Meteo (free, no key) -----------
# Endpoint for the forward forecast. Point at a self-hosted Open-Meteo if you
# have one; otherwise leave as the public API.
HINATION_GFS_URL=https://api.open-meteo.com/v1/forecast
# Open-Meteo model. gfs_seamless = NOAA GFS 13km hourly (Windy-style default).
HINATION_GFS_MODEL=gfs_seamless
# Forecast horizon in days (×24 = hours). GFS supports up to 16.
HINATION_FORECAST_DAYS=7
# Timezone the hourly timestamps are localized to.
HINATION_TIMEZONE=Asia/Ho_Chi_Minh
# HTTP timeout (seconds) per area request.
HINATION_GFS_TIMEOUT=30

# --- Antecedent history: ERA5 archive via Open-Meteo (seeds rolling windows)-
# Fetches ~30 observed days before the forecast so the model's 7/14/30-day
# features aren't empty. Turn off with false to predict on forecast-only.
HINATION_SEED_ANTECEDENT=true
HINATION_ERA5_ARCHIVE_URL=https://archive-api.open-meteo.com/v1/archive

# --- Scheduler / model ------------------------------------------------------
# How often the scheduler regenerates the forecast (hours).
HINATION_REFRESH_INTERVAL_HOURS=1
# Use the trained PyTorch multi-task net (true) or the heuristic v1 model.
HINATION_USE_V2_MODEL=true

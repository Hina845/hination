# ===========================================================================
# Root .gitignore for the hination monorepo
#   hination/     -> Python ML/forecast backend (FastAPI + scheduler)
#   hination-fe/  -> Next.js frontend (pnpm)
# ===========================================================================

# ---------------------------------------------------------------------------
# Node / Next.js (hination-fe)
# ---------------------------------------------------------------------------
node_modules/
.pnpm-store/
.next/
out/
dist/
build/
*.tsbuildinfo
next-env.d.ts

# ---------------------------------------------------------------------------
# Python (hination)
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.Python
venv/
.venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# ---------------------------------------------------------------------------
# Environment / secrets
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------------------------
# Local databases (regenerated at runtime)
# ---------------------------------------------------------------------------
*.sqlite
*.sqlite-shm
*.sqlite-wal
*.db

# ---------------------------------------------------------------------------
# Generated model output / predictions (regenerated by the pipeline)
# ---------------------------------------------------------------------------
# Ignore top-level data directory while keeping model/ and models/ tracked.
data/
hination/data/predictions/*.json

# ---------------------------------------------------------------------------
# ML models / trained weights (generated during training)
# ---------------------------------------------------------------------------
hination/data/features/*.json
hination/data/raw/era5/*.json
hination/data/raw/terrain/*.json
hination/data/raw/disasters/*.json

# ---------------------------------------------------------------------------
# Test / tooling artifacts (Playwright, screenshots)
# ---------------------------------------------------------------------------
.playwright-cli/
hination-fe/output/playwright/
playwright-report/
test-results/

# ---------------------------------------------------------------------------
# Logs & temp files
# ---------------------------------------------------------------------------
*.log
logs/
.tmp-*
tmp/
temp/
*.tmp

# ---------------------------------------------------------------------------
# Docker / data volumes
# ---------------------------------------------------------------------------
postgres_data/
redis_data/
rabbitmq_data/

# ---------------------------------------------------------------------------
# Packaged archives
# ---------------------------------------------------------------------------
*.tgz
*.tar.gz

# ---------------------------------------------------------------------------
# IDE / editor
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# ---------------------------------------------------------------------------
# OS cruft
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
